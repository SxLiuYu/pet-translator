# ============================================
# 毛孩子翻译官 - 环境配置
# ============================================

# 运行环境 (development / production)
# 生产模式会强制安全配置检查 (JWT_SECRET、CORS_ORIGINS)
ENVIRONMENT=development

# JWT 密钥 (生产模式必须设置强随机值)
# 生成示例: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# CORS 允许的来源 (生产模式禁止 *，用逗号分隔多个域名)
# 示例: https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# 服务器端口
HOST=0.0.0.0
PORT=8000

# 微信推送 (企业微信机器人 Webhook URL)
WECHAT_WEBHOOK=

# 微信推送 (Server酱 SCKEY)
SERVERCHAN_KEY=

# 默认宠物 ID (用于音频上传)
PET_ID=

# YAMNet 模型路径
YAMNET_MODEL_PATH=models/yamnet.tflite

# YOLOv8 模型
YOLO_MODEL=yolov8n.pt
