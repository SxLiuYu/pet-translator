# ============================================
# 毛孩子翻译官 - 环境配置
# ============================================

# 服务器端口
HOST=0.0.0.0
PORT=8000

# 微信推送 (企业微信机器人 Webhook URL)
WECHAT_WEBHOOK=

# 微信推送 (Server酱 SCKEY)
SERVERCHAN_KEY=

# 默认宠物 ID (用于音频上传)
PET_ID=

# YAMNet 模型路径
YAMNET_MODEL_PATH=models/yamnet.tflite

# YOLOv8 模型
YOLO_MODEL=yolov8n.pt
